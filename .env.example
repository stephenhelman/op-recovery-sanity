NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
RESEND_API_KEY=
NEXT_PUBLIC_NOTIFY_EMAIL=
NEXT_PUBLIC_COMPANY_NAME=

# Chat widget — AI mode (server-side only; NOT exposed to the browser)
ANTHROPIC_API_KEY=
# Optional model override. Default when unset: claude-sonnet-4-6.
# Set to claude-haiku-4-5-20251001 for a cheaper/faster model.
CHAT_MODEL=

# Chat widget — per-IP rate limit for /api/chat (Upstash Redis, server-side only).
# If unset/blank, the limiter fails OPEN (chat still works, just unthrottled).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=